{
  "manifest_version": 3,
  "name": "AI 지원서 작성 도우미",
  "version": "1.1.0",
  "description": "AI 기반 지원서 자동 작성 - React/Ant Design 커스텀 폼 완벽 지원",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "sidePanel"
  ],
  "host_permissions": [
    "http://localhost:5000/*",
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}
